# Required for the default `lite` and `pro` tiers (both use Gemini models).
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Alternative name — either variable works; we check both.
# GOOGLE_API_KEY=

# Required only for `--tier=max` or `--model anthropic:<model>`.
# Get one at https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=

# Override the vision model for every run (highest precedence after --model flag).
# Format: <provider>:<model>, e.g. anthropic:claude-opus-4-7
# LEARN_VIDEO_MODEL=

# Optional path override for config.toml (defaults look in repo root, then
# ~/.claude/scripts/learn_video/config.toml)
# LEARN_VIDEO_CONFIG=/path/to/config.toml

# Silence the huggingface_hub symlink warning on Windows (faster-whisper cache).
# HF_HUB_DISABLE_SYMLINKS_WARNING=1
